# Copia questo file in .env e compila i valori
# Il file .env è escluso dal git (vedere .gitignore)

# Sito Atlassian Cloud (senza https://)
ATLASSIAN_SITE=tuo-sito.atlassian.net

# Email dell'account Atlassian usato per le API
ATLASSIAN_EMAIL=tuo@email.com

# Personal API Token (https://id.atlassian.com/manage-profile/security/api-tokens)
# Alternativa: crea un file api-token.txt nella stessa cartella con solo il token
ATLASSIAN_TOKEN=your_api_token_here
